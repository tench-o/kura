{
  "name": "kura-db",
  "version": "0.1.0",
  "description": "SQLite-based general-purpose local database CLI & MCP Server",
  "type": "module",
  "bin": {
    "kura": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "rm -rf dist && npm run build:ui && npm run build:server",
    "build:ui": "cd ui && npm install && npm run build",
    "build:server": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "dev:ui": "cd ui && npx vite --port 5173",
    "dev:server": "tsx src/index.ts ui --dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tench-o/kura.git"
  },
  "keywords": [
    "sqlite",
    "database",
    "cli",
    "mcp",
    "local-database",
    "notion-like",
    "kura"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "hono": "^4.12.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
